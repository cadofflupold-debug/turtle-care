# Bmob server-side environment variables
# Copy this file to .env for local development, then fill in your own Bmob values.
# Never commit real keys.

BMOB_APPLICATION_ID=your_bmob_application_id
BMOB_REST_API_KEY=your_bmob_rest_api_key
BMOB_API_SAFE_CODE=your_bmob_api_safe_code
BMOB_API_BASE=https://api.bmobcloud.com/1
BMOB_FILE_API_BASE=https://api.bmobcloud.com/2
